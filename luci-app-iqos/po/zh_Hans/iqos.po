# custom_rules.htm 相关
msgid "Custom nftables Rules"
msgstr "自定义 nftables 规则"

msgid "Define custom nftables rules for advanced traffic control. Rules are applied to the appropriate hook based on direction."
msgstr "定义用于高级流量控制的自定义 nftables 规则。规则根据方向应用于相应的钩子。"

msgid "Egress Custom Rules (upload direction)"
msgstr "出口自定义规则（上传方向）"

msgid "These rules are inserted into the nftables chain \"filter_qos_egress\". Do not include \"table\" or \"chain\" definitions."
msgstr "这些规则被插入到 nftables 链 \"filter_qos_egress\" 中。请勿包含 \"table\" 或 \"chain\" 定义。"

msgid "Ingress Custom Rules (download direction)"
msgstr "入口自定义规则（下载方向）"

msgid "These rules are inserted into the nftables chain \"filter_qos_ingress\". Do not include \"table\" or \"chain\" definitions."
msgstr "这些规则被插入到 nftables 链 \"filter_qos_ingress\" 中。请勿包含 \"table\" 或 \"chain\" 定义。"

msgid "Full Table Custom Rules (advanced)"
msgstr "完整表自定义规则（高级）"

msgid "Define a complete nftables table \"inet iqos_custom\". The wrapper will be added automatically. Only supports tables prefixed with \"iqos_custom_*\"."
msgstr "定义一个完整的 nftables 表 \"inet iqos_custom\"。系统将自动添加。仅支持以\"iqos_custom_*\"开头的表。"

msgid "Back to Custom Rules"
msgstr "返回自定义规则"

msgid "Custom rules saved. QoS not restarted."
msgstr "自定义规则已保存。QoS未重新启动。"


# ratelimit.htm 相关
msgid "Rate Limits"
msgstr "速率限制"

msgid "Configure per-device bandwidth limits using nftables meters. Limits are applied based on the source IP of devices, making it easy to control traffic for specific devices or subnets."
msgstr "使用 nftables 计量器配置每设备带宽限制。限制基于设备的源 IP 应用，便于控制特定设备或子网的流量。"

msgid "Target Devices"
msgstr "目标设备"

msgid "Download Limit (Kbit/s)"
msgstr "下载限制（Kbit/s）"

msgid "Upload Limit (Kbit/s)"
msgstr "上传限制（Kbit/s）"

msgid "Burst Factor"
msgstr "突发因子"

msgid "Delete"
msgstr "删除"

